# openaiy environment — copy this file to "openaiy.env" and fill in your key.
#
#     cp openaiy.env.example openaiy.env
#     # then edit openaiy.env and paste your real key
#
# openaiy.env is git-ignored on purpose, so your secret never gets committed.
# install.sh writes this file for you; this template just documents the format.
#
# Get a key at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-replace-with-your-openai-api-key
