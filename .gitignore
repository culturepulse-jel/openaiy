# Secrets — never commit API keys or anything holding sensitive data.
# Keep these patterns broad on purpose: the goal is that a secret can never be
# committed by accident, even in a file we didn't think of.
openaiy.env
.env
*.env
*.env.*
# but DO allow a committed, secret-free template (negation must be its own line;
# git does not support trailing comments on pattern lines)
!*.env.example
secrets*
*.secret
*.key
*.pem

# Python virtual environment (created by install.sh)
venv/
.venv/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/

# Temp audio
*.wav
/tmp/aiy_*.wav

# Editor / OS cruft
.DS_Store
*.swp
